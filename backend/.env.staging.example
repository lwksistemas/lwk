# =============================================================================
# STAGING (Heroku app: lwksistemas-staging) — NÃO use DATABASE_URL de produção.
# =============================================================================
# 1) Copie:  cp .env.staging.example .env.staging
# 2) Preencha DATABASE_URL (só staging):
#      heroku config:get DATABASE_URL -a lwksistemas-staging
# 3) Nunca commite .env.staging (está no .gitignore na raiz do repo).
#
# API local usando o Postgres de STAGING (testes sem tocar em lwksistemas):
#   cd backend
#   set -a && source ../.env.staging && set +a   # ou: export $(grep -v '^#' .env.staging | xargs)
#   python manage.py runserver
#
# Deploy código para staging:
#   git push heroku-staging main
#
# GitHub → deploy automático no STAGING (painel Heroku):
#   App lwksistemas-staging → Deploy → conectar GitHub → repo lwksistemas/lwk → branch main
#   (Opcional: branch dedicada "staging" só para este app.)
#
# URL pública do staging:
#   https://lwksistemas-staging-fd8255645aeb.herokuapp.com/
#
# Next.js local apontando para esta API: ver frontend/.env.staging.local.example
# =============================================================================

# Obrigatório: URI do Postgres do addon do app lwksistemas-staging
DATABASE_URL=

# Para espelhar o mesmo settings que a dyno Heroku staging
DJANGO_SETTINGS_MODULE=config.settings_production

# Quando roda manage.py na sua máquina contra o banco staging, o Host é "localhost"
ALLOWED_HOSTS=localhost,127.0.0.1,lwksistemas-staging-fd8255645aeb.herokuapp.com,.herokuapp.com

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

USE_REDIS=false

# Opcional: copiar do painel staging depois (sandbox), nunca chaves de produção sem querer
# ASAAS_API_KEY=
# ASAAS_SANDBOX=true
