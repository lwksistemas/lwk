SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgresql://user:password@localhost:5432/multistore_db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Configurações de Email - Gmail
# Para usar Gmail, você precisa criar uma "Senha de App":
# 1. Acesse: https://myaccount.google.com/apppasswords
# 2. Crie uma senha de app para "Django App"
# 3. Use a senha de 16 caracteres gerada (sem espaços)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-de-app-aqui
DEFAULT_FROM_EMAIL=Sistema Multi-Loja <seu-email@gmail.com>

# Para desenvolvimento (mostrar emails no console):
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
