# Configuração para Produção (Heroku/Render)
# Copie para .env em produção

# OBRIGATÓRIO: Gere uma chave secreta forte
SECRET_KEY=sua-chave-secreta-super-segura-aqui-mude-isso

# OBRIGATÓRIO: Configure seus domínios
ALLOWED_HOSTS=seu-app.herokuapp.com,seu-app.onrender.com

# OBRIGATÓRIO: URL do banco PostgreSQL (auto-configurado no Heroku)
DATABASE_URL=postgresql://user:password@host:5432/database

# Segurança
DEBUG=False

# CORS - Domínios permitidos para frontend
CORS_ORIGINS=https://seu-frontend.vercel.app,https://seu-dominio.com

# Django Settings Module
DJANGO_SETTINGS_MODULE=config.settings_production

# Opcional: Throttle da API (formato DRF: número/unidade, ex. 2000/hour)
# DRF_THROTTLE_ANON_RATE=100/hour
# DRF_THROTTLE_USER_RATE=2000/hour

# =============================================================================
# RENDER (API de backup — failover se Heroku cair)
# =============================================================================
# 1) Push do repo GitHub com render.yaml na raiz → Render → New → Blueprint → ligar repo → branch master
#    (ou New → Web Service: Runtime Python, Root Directory = backend)
# 2) Build Command:  pip install -r requirements.txt && python manage.py collectstatic --noinput
#    Pre-Deploy:      python fix_suporte_migration.py 2>/dev/null || true && python manage.py migrate --noinput && python manage.py setup_initial_data
#    Start Command:   gunicorn config.wsgi --workers 2 --threads 4 --worker-class gthread --timeout 30 --bind 0.0.0.0:$PORT
#    Health Check Path: /api/superadmin/health/
# 3) Variáveis obrigatórias (espelhar Heroku — o mesmo banco = os mesmos dados):
#    DJANGO_SETTINGS_MODULE=config.settings_production
#    DISABLE_STATICFILES_MANIFEST=true
#    SECRET_KEY=           (mesmo valor do Heroku)
#    DATABASE_URL=         (mesmo Postgres do Heroku; ver Credenciais no addon Postgres → URI externa se precisar)
#    ALLOWED_HOSTS=        seu-app.onrender.com,.onrender.com
#    SITE_URL=             https://seu-app.onrender.com
#    FRONTEND_URL=         https://lwksistemas.com.br
# 4) Copiar restantes do Heroku: heroku config -a lwksistemas
#    (EMAIL_HOST_*, ASAAS_*, GOOGLE_*, CLOUDINARY_*, REDIS_URL opcional, etc.)
# 5) Vercel → NEXT_PUBLIC_API_BACKUP_URL=https://seu-app.onrender.com
#    (com ou sem /api conforme o front: o api-client aceita os dois formatos)
#    NEXT_PUBLIC_ENABLE_LOJA_FAILOVER=true  → failover automático também nas rotas de loja (com MESMO DATABASE_URL)
#
# Script (API Render): ./scripts/render-sync-env-from-heroku.sh
#   RENDER_ALLOWED_HOSTS_EXTRA=seu-app.onrender.com,.onrender.com
#   RENDER_SITE_URL=https://seu-app.onrender.com   # opcional; sobrescreve SITE_URL do Heroku no backup
# =============================================================================
