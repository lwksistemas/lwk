# Gunicorn: 4 workers × 2 threads = 8 req simultâneas (gthread para I/O)
web: cd backend && gunicorn config.wsgi --workers 4 --threads 2 --worker-class gthread --worker-tmp-dir /dev/shm --max-requests 1000 --max-requests-jitter 50 --timeout 120 --graceful-timeout 30 --keep-alive 5 --log-file - --access-logfile - --error-logfile -
release: cd backend && python fix_suporte_migration.py 2>/dev/null || true && python manage.py migrate --noinput && python fix_relatorio_comissao_table.py && python manage.py ensure_estoque_produto_fields && python manage.py migrate_all_lojas && python manage.py limpar_tabelas_extras_schema --slug felix 2>/dev/null || true && python manage.py setup_initial_data
