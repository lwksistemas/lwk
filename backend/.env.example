SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgresql://user:password@localhost:5432/multistore_db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Webhooks (mesmo token configurado no painel Asaas / MP Developers)
# WEBHOOK_STRICT_VERIFY=false  # só dev local sem token
# ASAAS_WEBHOOK_TOKEN=
# ASAAS_LOJA_WEBHOOK_TOKEN=
# MERCADOPAGO_WEBHOOK_SECRET=

# JWT em cookies httpOnly (produção: true no backend + NEXT_PUBLIC no frontend)
# JWT_USE_HTTPONLY_COOKIES=false
# JWT_COOKIE_DOMAIN=.lwksistemas.com.br

# MFA TOTP (superadmin/suporte) — opcional: MFA_ENFORCE_TYPES=superadmin,suporte
# MFA_TOTP_ISSUER=LWK Sistemas

# E-mail transacional — ver docs/EMAIL_ENTREGA.md
# Recomendado (produção): Resend + domínio lwksistemas.com.br
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=LWK Sistemas <noreply@lwksistemas.com.br>
DEFAULT_REPLY_TO=contato@lwksistemas.com.br

# Fallback Gmail (senha de app: https://myaccount.google.com/apppasswords)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-de-app-aqui

# Desenvolvimento (emails no terminal):
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Nota Fiscal Asaas (emissão ao confirmar pagamento da assinatura)
# Serviço municipal conforme prefeitura da conta LWK no Asaas (opcional)
# ASAAS_INVOICE_SERVICE_CODE=
# ASAAS_INVOICE_SERVICE_NAME=Software sob demanda / Assinatura de sistema
# ASAAS_INVOICE_SERVICE_ID=
