# URL do backend Railway (produção). Configure no Vercel (Production), não commite .env.production.
# Staging: branch staging → Preview env NEXT_PUBLIC_API_URL (ver .env.staging.local.example).
NEXT_PUBLIC_API_URL=https://lwks-backend-production.up.railway.app

# JWT em cookies httpOnly (mesmo valor que JWT_USE_HTTPONLY_COOKIES no backend)
NEXT_PUBLIC_JWT_HTTPONLY_COOKIES=true
