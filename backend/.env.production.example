# Configuração para Produção (Heroku/Render)
# Copie para .env em produção

# OBRIGATÓRIO: Gere uma chave secreta forte
SECRET_KEY=sua-chave-secreta-super-segura-aqui-mude-isso

# OBRIGATÓRIO: Configure seus domínios
ALLOWED_HOSTS=seu-app.herokuapp.com,seu-app.onrender.com

# OBRIGATÓRIO: URL do banco PostgreSQL (auto-configurado no Heroku)
DATABASE_URL=postgresql://user:password@host:5432/database

# Segurança
DEBUG=False

# CORS - Domínios permitidos para frontend
CORS_ORIGINS=https://seu-frontend.vercel.app,https://seu-dominio.com

# Django Settings Module
DJANGO_SETTINGS_MODULE=config.settings_production

# Opcional: Throttle da API (formato DRF: número/unidade, ex. 2000/hour)
# DRF_THROTTLE_ANON_RATE=100/hour
# DRF_THROTTLE_USER_RATE=2000/hour
