{
  "name": "multi-store-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS='--max-old-space-size=6144' next build --webpack",
    "postbuild": "echo 'PWA desabilitado temporariamente'",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:crm-public": "playwright test e2e/crm-smoke.spec.ts e2e/crm-assinatura-publica.spec.ts --grep-invert autenticado",
    "test:e2e:crm-auth": "playwright test e2e/crm-smoke.spec.ts --grep autenticado",
    "test:e2e:clinica-public": "playwright test e2e/clinica-smoke.spec.ts --grep-invert autenticado",
    "test:e2e:clinica-auth": "playwright test e2e/clinica-smoke.spec.ts --grep autenticado",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.6.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.460.0",
    "next": "16.2.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^20.19.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.30.0",
    "eslint-config-next": "16.2.10",
    "postcss": "^8",
    "tailwindcss": "^4.3.2",
    "typescript": "5.9.3",
    "vitest": "^3.2.6"
  }
}
