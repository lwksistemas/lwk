# Configuração para produção (ex.: variáveis do host onde o Django roda)
# Copie para .env em produção

# OBRIGATÓRIO: Gere uma chave secreta forte
SECRET_KEY=sua-chave-secreta-super-segura-aqui-mude-isso

# OBRIGATÓRIO: Configure seus domínios (hostnames do backend)
ALLOWED_HOSTS=api.seudominio.com,.seudominio.com

# OBRIGATÓRIO: URL do banco PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/database

# Segurança
DEBUG=False

# CORS - Domínios permitidos para frontend
CORS_ORIGINS=https://seudominio.com

# Django Settings Module
DJANGO_SETTINGS_MODULE=config.settings_production

# URL pública da API (https, sem barra final) — usada em e-mails, links e diagnósticos
SITE_URL=https://api.seudominio.com

# Opcional: atrás de proxy TLS (load balancer, PaaS) — confia em X-Forwarded-Proto
# USE_FORWARDED_SSL=true

# Opcional: tenant por subdomínio — não tratar estes hosts como slug de loja
# TENANT_IGNORE_SUBDOMAIN_SUFFIXES=.seudominio.com
# TENANT_IGNORE_SUBDOMAIN_PREFIXES=api,staging

# Opcional: Throttle da API (formato DRF: número/unidade, ex. 2000/hour)
# DRF_THROTTLE_ANON_RATE=100/hour
# DRF_THROTTLE_USER_RATE=2000/hour
