NEXT_PUBLIC_API_URL=https://lwksistemas-38ad47519238.herokuapp.com/api
# Backup (Render) para failover quando Heroku estiver indisponível
NEXT_PUBLIC_API_BACKUP_URL=https://lwksistemas-backup-ewgo.onrender.com
# Failover também para rotas de loja (info_publica, auth/loja, etc.).
# Heroku e Render já usam o mesmo DATABASE_URL (banco único), então podemos habilitar.
NEXT_PUBLIC_ENABLE_LOJA_FAILOVER=true
